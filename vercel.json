{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/health-check",
      "schedule": "*/15 * * * *"
    }
  ],
  "functions": {
    "src/app/api/cron/health-check/route.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}